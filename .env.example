# Core
NODE_ENV=development
APP_PORT=3000
API_PORT=8787

# Deepgram
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_API_KEY
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en

# OpenRouter (Qwen3 translation)
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_FALLBACK_MODELS=openrouter/auto
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Rizerve Voice Console

# Pipecat
PIPECAT_LOG_LEVEL=info
PIPECAT_SAMPLE_RATE=16000
PIPECAT_CHANNELS=1

# UI
UI_BASE_URL=http://localhost:3000
VITE_APP_TITLE=Rizerve Voice Console
VITE_DEEPGRAM_MODEL=nova-2
VITE_SOURCE_LANGUAGE=en
VITE_TARGET_LANGUAGE=hi
