{
  "name": "rizerve-stack",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "node --env-file=.env server/index.mjs",
    "build": "tsc -b && vite build",
